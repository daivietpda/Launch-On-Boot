<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/activity_main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:paddingLeft="32dp"
    tools:context="news.androidtv.launchonboot.MainActivity">

    <RelativeLayout
        android:layout_width="480dp"
        android:paddingTop="32dp"
        android:paddingBottom="32dp"
        android:id="@+id/leftPane"
        android:layout_height="match_parent">
        <ImageView
            android:layout_width="400dp"
            android:foregroundGravity="center_horizontal"
            android:src="@drawable/banner"
            android:id="@+id/app_banner"
            android:layout_height="wrap_content" />
        <TextView
            android:layout_width="match_parent"
            android:layout_below="@id/app_banner"
            android:textSize="16sp"
            android:paddingEnd="32dp"
            android:paddingStart="32dp"
            android:paddingTop="8dp"
            android:text="@string/credits"
            android:layout_height="wrap_content" />
    </RelativeLayout>

    <RelativeLayout android:layout_width="match_parent"
        android:id="@+id/settings"
        android:paddingEnd="32dp"
        android:paddingTop="72dp"
        android:paddingStart="16dp"
        android:background="@color/darker"
        android:layout_toEndOf="@id/leftPane"
        android:layout_height="match_parent"
        xmlns:android="http://schemas.android.com/apk/res/android">
        <Switch
            android:layout_width="wrap_content"
            android:id="@+id/switch_enable"
            android:layout_height="wrap_content" />
        <TextView
            android:layout_width="wrap_content"
            android:text="@string/label_enabled"
            android:layout_toRightOf="@id/switch_enable"
            android:layout_marginTop="4dp"
            android:layout_marginLeft="16dp"
            android:layout_height="wrap_content" />
        <Switch
            android:layout_width="wrap_content"
            android:id="@+id/switch_live_channels"
            android:layout_below="@id/switch_enable"
            android:layout_marginTop="8dp"
            android:layout_height="wrap_content" />
        <TextView
            android:layout_width="wrap_content"
            android:text="@string/label_launch_tv_app"
            android:layout_toRightOf="@id/switch_live_channels"
            android:layout_below="@id/switch_enable"
            android:layout_marginTop="12dp"
            android:layout_marginLeft="16dp"
            android:layout_height="wrap_content" />
        <Switch
            android:layout_width="wrap_content"
            android:id="@+id/switch_wakeup"
            android:layout_below="@id/switch_live_channels"
            android:layout_marginTop="8dp"
            android:layout_height="wrap_content" />
        <TextView
            android:layout_width="wrap_content"
            android:text="@string/msg_wakeup"
            android:layout_toRightOf="@id/switch_wakeup"
            android:layout_below="@id/switch_live_channels"
            android:layout_marginTop="12dp"
            android:layout_marginLeft="16dp"
            android:layout_height="wrap_content" />
        <Button
            android:layout_width="wrap_content"
            android:id="@+id/button_select_app"
            android:layout_below="@id/switch_wakeup"
            android:layout_marginTop="16dp"
            android:background="@color/colorPrimaryDark"
            android:text="@string/label_select_app"
            android:layout_height="wrap_content" />
        <TextView
            android:layout_width="wrap_content"
            android:id="@+id/text_package_name"
            android:text="com.felker"
            android:layout_marginTop="8dp"
            android:layout_below="@id/button_select_app"
            android:layout_height="wrap_content" />
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:id="@+id/delay_container"
            android:layout_below="@id/text_package_name"
            android:layout_marginTop="16dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/launch_delay_label"/>
            <EditText
                android:layout_width="60dp"
                android:layout_height="wrap_content"
                android:id="@+id/edit_delay"
                android:inputType="number"
                android:text="0"
                android:layout_marginStart="8dp"/>
        </LinearLayout>
        <Button
            android:layout_width="wrap_content"
            android:text="@string/label_test"
            android:id="@+id/button_test"
            android:background="@color/colorPrimaryDark"
            android:layout_below="@id/delay_container"
            android:layout_marginTop="32dp"
            android:layout_height="wrap_content" />
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@id/button_test"
            android:layout_marginTop="32dp"
            android:text="@string/msg_accessibility_required"
            android:textColor="@android:color/white"
            android:textSize="14sp"
            android:alpha="0.7"
            android:id="@+id/text_accessibility_info"/>
        <Button
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/text_accessibility_info"
            android:text="@string/label_go_to_settings"
            android:id="@+id/button_go_to_accessibility"
            android:layout_marginTop="16dp"
            android:background="@color/colorPrimaryDark"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"/>
    </RelativeLayout>
</RelativeLayout>
